<!DOCTYPE html>
<html lang="id">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= produk.nama_produk %> - KopiDaeng</title>
  <link rel="stylesheet" href="/stylesheets/style.css" />

  <style>
    .detail-produk { padding: 30px; }
    .produk-wrapper { display: flex; gap: 30px; align-items: flex-start; }
    .produk-gambar { width: 350px; height: 350px; border-radius: 15px; overflow: hidden; flex-shrink: 0; }
    .produk-gambar img { width: 100%; height: 100%; object-fit: cover; }
    .produk-info { flex: 1; }
    .rating-stars { color: gold; font-size: 20px; }
    .ulasan-card { background: white; padding: 20px; border-radius: 12px; margin-bottom: 15px; border: 1px solid #eee; }
    .ulasan-rating { color: gold; font-size: 18px; }
    .btn-lihat { background: #d87a2f; color: white; padding: 8px 16px; border-radius: 8px; margin-top: 10px; cursor: pointer; border: none; font-weight: bold; }
    hr { margin: 30px 0; border: none; border-bottom: 1px solid #f5f1f1; }
  </style>
</head>

<body>

  <%- include('../partials/navbar') %>

  <div class="main-container detail-produk">

    <!-- ================== PRODUK ================== -->
    <div class="produk-wrapper">

      <!-- GAMBAR -->
      <div class="produk-gambar">
        <img src="/images/<%= produk.gambar %>" alt="<%= produk.nama_produk %>">
      </div>

      <!-- INFO PRODUK -->
      <div class="produk-info">
        <h1><%= produk.nama_produk %></h1>

        <!-- RATING -->
        <div class="rating-box">
          <% if (ulasan.length > 0) { 
            let total = 0;
            ulasan.forEach(u => total += u.rating);
            let avg = total / ulasan.length;
          %>

            <span class="rating-stars">
              <% for (let i = 0; i < Math.round(avg); i++) { %> ★ <% } %>
            </span>
            <span><%= avg.toFixed(1) %> • <%= ulasan.length %> ulasan</span>

          <% } else { %>
            <span>Belum ada ulasan</span>
          <% } %>
        </div>

        <h2>Rp <%= produk.harga.toLocaleString('id-ID') %></h2>

        <p><%= produk.deskripsi %></p>

        <a href="/pesanan/tambah/<%= produk.id %>" class="btn">Pesan Sekarang</a>
      </div>

    </div>

    <hr>

    <!-- ================== ULASAN ================== -->
    <h2>Ulasan Pelanggan</h2>

    <% if (ulasan.length === 0) { %>
      <p>Belum ada ulasan untuk produk ini.</p>
    <% } %>

    <div id="ulasanContainer">

      <% ulasan.forEach((u, index) => { %>
        <div class="ulasan-card ulasan-item" style="<%= index >= 3 ? 'display:none;' : '' %>">

          <div class="ulasan-rating">
            <% for (let i = 0; i < u.rating; i++) { %> ★ <% } %>
          </div>

          <!-- 🔥 FIX PENTING: gunakan `komentar` -->
          <p><%= u.komentar %></p>

          <small><%= new Date(u.tanggal).toLocaleDateString('id-ID') %></small>
        </div>
      <% }) %>

    </div>

    <% if (ulasan.length > 3) { %>
      <button class="btn-lihat" id="btnToggle">Lihat Semua</button>
    <% } %>

  </div> 

<script>
  const btn = document.getElementById("btnToggle");
  const items = document.querySelectorAll(".ulasan-item");

  if (btn) {
    btn.addEventListener("click", () => {
      const isShowAll = btn.innerText === "Tutup";

      if (isShowAll) {
        items.forEach((item, idx) => {
          item.style.display = idx < 3 ? "block" : "none";
        });
        btn.innerText = "Lihat Semua";
      } else {
        items.forEach(item => item.style.display = "block");
        btn.innerText = "Tutup";
      }
    });
  }
</script>

</body>

</html>
