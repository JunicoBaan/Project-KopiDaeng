<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tambah Produk - KopiDaeng</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

  <main class="dashboard-main-content">
    <div class="header-section">
      <h1>Tambah Produk Baru</h1>
    </div>

    <form action="/produk/create" method="POST" enctype="multipart/form-data" class="content-form">
      
      <div class="form-group">
        <label for="nama_produk">Nama Produk</label>
        <input type="text" id="nama_produk" name="nama_produk" placeholder="Contoh: Kopi Susu Gula Aren" required>
      </div>

      <!-- ✅ Tambahan: Pilihan Kategori -->
      <div class="form-group">
        <label for="id_kategori">Kategori</label>
        <select id="id_kategori" name="id_kategori" required>
          <option value="">-- Pilih Kategori --</option>
          <% if (kategori && kategori.length > 0) { %>
            <% kategori.forEach(k => { %>
              <option value="<%= k.id %>"><%= k.nama_kategori %></option>
            <% }) %>
          <% } %>
        </select>
      </div>

      <div class="form-group">
        <label for="deskripsi">Deskripsi</label>
        <textarea id="deskripsi" name="deskripsi" placeholder="Jelaskan keunikan produk kopi Anda di sini..." required></textarea>
      </div>

      <div class="form-group">
        <label for="harga">Harga (Rp)</label>
        <input type="number" id="harga" name="harga" placeholder="Contoh: 25000 (tulis angka saja)" required>
      </div>

      <div class="form-group">
        <label for="stok">Stok</label>
        <input type="text" id="stok" name="stok" required>
      </div>

      <div class="form-group">
        <label for="gambar">Gambar Produk</label>
        <div class="file-input-wrapper">
            <input type="file" name="gambar" id="gambar" accept="image/*">
            <span class="file-input-label">Klik atau seret gambar ke sini</span>
            <span class="file-input-hint">JPG, PNG, atau WEBP.</span>
        </div>
      </div>
      
      <div class="form-actions">
        <button type="submit" class="btn">Simpan Produk</button>
        <a href="/produk" class="link-kembali">Batal</a>
      </div>

    </form>
  </div>

  <script>
    const fileInput = document.getElementById('gambar');
    const fileLabel = document.querySelector('.file-input-label');
    const originalLabel = fileLabel.textContent;

    fileInput.addEventListener('change', function(e) {
      const fileName = e.target.files[0] ? e.target.files[0].name : originalLabel;
      fileLabel.textContent = fileName;
    });
  </script>

</body>
</html>
