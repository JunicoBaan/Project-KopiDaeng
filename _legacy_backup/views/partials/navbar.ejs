<nav class="user-navbar">
  <div class="nav-logo">
    <a href="/ ">☕ KopiDaeng</a>
  </div>

  <!-- SEARCH BAR -->
  <div class="nav-search">
    <form action="/produk/katalog" method="GET">
      <input type="text" name="q" placeholder="Cari kopi favorit kamu..." value="<%= typeof query !== 'undefined' ? query : '' %>">
      <button type="submit"><i class="fa fa-search"></i></button>
    </form>
  </div>

  <div class="nav-right">
    <a href="/produk/katalog" class="cart-link">Katalog</a>
  </div>

  <!-- KERANJANG & USER -->
  <div class="nav-right">
    <a href="/pesanan/saya" class="cart-link">
      <i class="fa fa-shopping-cart"></i> <span>Keranjang Pesanan</span>
    </a>

    <% if (user) { %>
      <span class="greeting">👋 Hai, <%= user.nama %></span>
      <a class="btn-logout" href="/users/logout">Logout</a>
    <% } else { %>
      <a class="btn-login" href="/users/login">Login</a>
    <% } %>
  </div>
</nav>

<!-- Font Awesome (icon keranjang + search) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
